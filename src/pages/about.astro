---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const values = [
  { icon: '/images/textures/item/nether_star.png', title: '系统思维', desc: '把复杂问题拆解为可处理的子系统，寻找杠杆点', color: '#9C27B0' },
  { icon: '/images/textures/item/compass_00.png', title: '持续迭代', desc: '没有完美，只有不断改进。MVP优先，快速验证', color: '#4CAF50' },
  { icon: '/images/textures/item/experience_bottle.png', title: '学习优先', desc: '把学习当成投资而非消耗，优先积累复利型知识', color: '#4FC3F7' },
  { icon: '/images/textures/item/spyglass.png', title: '长期主义', desc: '短期噪音中寻找长期信号，做时间的朋友', color: '#FFD54F' },
];

const stack = [
  { layer: 'Interface', desc: 'React / Vue / Astro', color: '#4FC3F7', bg: '#E1F5FE' },
  { layer: 'Logic', desc: 'JavaScript / TypeScript / Python', color: '#388E3C', bg: '#E8F5E9' },
  { layer: 'AI Tools', desc: 'Claude / GPT / Cursor / AI Agents', color: '#F9A825', bg: '#FFF8E1' },
  { layer: 'Thinking', desc: 'Systems Thinking / First Principles', color: '#7B1FA2', bg: '#F3E5F5' },
];

const timeline = [
  { year: '2024', event: '开始探索 AI/Agent 工程实践，构建个人操作系统', icon: '🤖', color: '#4CAF50' },
  { year: '2023', event: '深入前端开发，学习 React 生态体系', icon: '⚛️', color: '#4FC3F7' },
  { year: '2022', event: '接触编程，从 HTML/CSS 开始的奇妙旅程', icon: '🌱', color: '#8BC34A' },
];
---

<Layout title="我的操作系统 - 山禾">
  <Header />

  <main class="py-8" transition:animate="fade">
    <div class="container-pixel">

      <!-- 页面标题 -->
      <div class="text-center mb-12 animate-fade-in">
        <div class="inline-block bg-[#FBF2DB] border-2 border-[#A0522D] px-4 py-1 text-xs text-[#8B4513] pixel-font mb-4">
          MY OPERATING SYSTEM
        </div>
        <h1 class="pixel-font text-4xl md:text-5xl text-[#388E3C] mb-4" style="text-shadow: 3px 3px 0 #654321;">
          我的操作系统
        </h1>
        <p class="text-[#666666] max-w-xl mx-auto leading-relaxed">
          不仅仅是"关于我"，这里记录的是我的思维底层——价值观、决策框架、学习方式。
        </p>
        <div class="pixel-line max-w-md mx-auto mt-6"></div>
      </div>

      <!-- 个人信息卡片 -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="md:col-span-1">
          <div class="pixel-card p-6 text-center bg-[#FBF2DB]">
            <!-- 玩家头像（原版草方块人） -->
            <div class="relative w-32 h-32 mx-auto mb-4 animate-float">
              <div class="w-full h-full bg-[#4CAF50] border-4 border-[#654321] relative overflow-hidden" style="box-shadow: 4px 4px 0 #8B4513;">
                <div class="absolute top-0 left-0 right-0 h-[28%] bg-[#66BB6A]"></div>
                <div class="absolute bottom-0 left-0 right-0 h-[72%] bg-[#8B4513]"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <img src="/images/icons/player.png" alt="山禾" class="w-24 h-24 object-contain mc-icon relative z-10" />
                </div>
              </div>
              <div class="absolute -bottom-1 -right-1 w-5 h-5 bg-[#4CAF50] border-2 border-[#388E3C] rounded-full flex items-center justify-center">
                <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
              </div>
            </div>
            <div class="pixel-font text-2xl text-[#593925] mb-1">山禾</div>
            <div class="text-sm text-[#8B4513] mb-4 pixel-font">开发者 · 探索者</div>
            <div class="space-y-2">
              <div class="mc-tag mc-tag-green w-full justify-center">前端开发</div>
              <div class="mc-tag mc-tag-blue w-full justify-center">AI 工程</div>
              <div class="mc-tag mc-tag-gold w-full justify-center">创造者</div>
            </div>
          </div>
        </div>

        <div class="md:col-span-2 space-y-4">
          <div class="pixel-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-4 h-4 bg-[#4CAF50] border-2 border-[#654321]"></div>
              <span class="text-xs text-[#8B4513] pixel-font">// BOOT MESSAGE</span>
            </div>
            <p class="text-[#593925] leading-relaxed mb-3">
              你好，我是山禾。一个热爱技术、相信工具改变思维的开发者。
              我把个人网站做成"操作系统"，因为我相信一个人的思维方式比履历更重要。
            </p>
            <p class="text-[#8B4513] leading-relaxed text-sm">
              我处于 AI/Agent 时代的入口——这不只是技术迭代，而是认知升级的时刻。
              我想探索人类智慧与 AI 协作的最佳范式。
            </p>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="pixel-card p-4 bg-[#E8F5E9]">
              <div class="text-xs text-[#8B4513] pixel-font mb-2">🎯 当前专注</div>
              <div class="flex items-center gap-2">
                <img src="/images/textures/item/diamond_pickaxe.png" alt="" class="w-7 h-7 mc-icon" />
                <span class="text-sm text-[#388E3C] pixel-font">AI Agent 工程</span>
              </div>
            </div>
            <div class="pixel-card p-4 bg-[#FFF8E1]">
              <div class="text-xs text-[#8B4513] pixel-font mb-2">📚 学习中</div>
              <div class="flex items-center gap-2">
                <img src="/images/textures/item/book.png" alt="" class="w-7 h-7 mc-icon" />
                <span class="text-sm text-[#F9A825] pixel-font">系统思维</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 核心价值观 -->
      <section class="mb-12 animate-fade-in">
        <div class="flex items-center gap-3 mb-6">
          <img src="/images/textures/item/nether_star.png" alt="" class="w-8 h-8 mc-icon" />
          <h2 class="pixel-font text-2xl text-[#388E3C]" style="text-shadow: 2px 2px 0 #654321;">核心价值观</h2>
          <div class="flex-1 pixel-line"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {values.map((v) => (
            <div class="pixel-card p-5 flex gap-4 card-hover">
              <div class="mc-icon-frame flex-shrink-0" style={`background: linear-gradient(180deg, ${v.color}cc 0%, ${v.color}88 100%);`}>
                <img src={v.icon} alt="" class="w-7 h-7 mc-icon relative z-10" />
              </div>
              <div>
                <h3 class="pixel-font text-base text-[#593925] mb-1">{v.title}</h3>
                <p class="text-sm text-[#8B4513] leading-relaxed">{v.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- 决策堆栈 -->
      <section class="mb-12 animate-fade-in">
        <div class="flex items-center gap-3 mb-6">
          <img src="/images/textures/item/knowledge_book.png" alt="" class="w-8 h-8 mc-icon" />
          <h2 class="pixel-font text-2xl text-[#388E3C]" style="text-shadow: 2px 2px 0 #654321;">决策堆栈</h2>
          <div class="flex-1 pixel-line"></div>
        </div>
        <div class="pixel-card p-6 bg-[#8D6E63]">
          <div class="text-xs text-[#FFF3E0] pixel-font mb-4 opacity-70">// STACK LAYERS (从上到下)</div>
          <div class="space-y-3">
            {stack.map((s, i) => (
              <div class="flex items-center gap-4">
                <div class="text-[#FFF3E0] pixel-font text-sm w-8 opacity-60">{String(i + 1).padStart(2, '0')}</div>
                <div class="flex-1 flex items-center gap-3 px-4 py-2.5 border-l-4" style={`background: ${s.bg}; border-color: ${s.color};`}>
                  <span class="text-sm pixel-font font-bold" style={`color: ${s.color};`}>{s.layer}</span>
                  <span class="text-[#593925] text-sm">→ {s.desc}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- 成长路径 -->
      <section class="mb-12 animate-fade-in">
        <div class="flex items-center gap-3 mb-6">
          <img src="/images/textures/item/map.png" alt="" class="w-8 h-8 mc-icon" />
          <h2 class="pixel-font text-2xl text-[#388E3C]" style="text-shadow: 2px 2px 0 #654321;">成长路径</h2>
          <div class="flex-1 pixel-line"></div>
        </div>
        <div class="space-y-4">
          {timeline.map((t, i) => (
            <div class="flex gap-4 items-start animate-fade-in" style={`animation-delay: ${i * 0.1}s;`}>
              <div class="text-3xl animate-float" style={`animation-delay: ${i * 0.5}s;`}>{t.icon}</div>
              <div class="flex-1 pixel-card p-4 card-hover">
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-3 h-3 border-2 border-[#654321]" style={`background: ${t.color};`}></div>
                  <span class="text-xs text-[#8B4513] pixel-font">{t.year}</span>
                </div>
                <p class="text-sm text-[#593925]">{t.event}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

    </div>
  </main>

  <Footer />
</Layout>
