---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Particles from '../components/Particles.astro';
---

<Layout title="山禾 - 首页">
  <Particles />
  <Header />

  <main class="min-h-[80vh] flex items-center justify-center">
    <div class="container-pixel py-20">
      <div class="text-center">
        <!-- 大标题 -->
        <h1 class="pixel-font text-5xl md:text-7xl text-[#388E3C] mb-6 animate-fade-in">
          山禾
        </h1>

        <!-- 副标题 -->
        <p class="text-xl md:text-2xl text-[#666666] mb-8 animate-fade-in delay-100">
          一位热爱技术的开发者
        </p>

        <!-- 简短介绍 -->
        <p class="max-w-lg mx-auto text-[#888888] mb-12 animate-fade-in delay-200">
          专注于前端开发，喜欢探索新技术，喜欢创造有趣的东西
        </p>

        <!-- 导航按钮 -->
        <div class="flex flex-wrap gap-4 justify-center animate-fade-in delay-300">
          <a href="/about" class="btn-mc px-8 py-3 pixel-font text-white text-lg">
            关于我
          </a>
          <a href="/skills" class="btn-mc px-8 py-3 pixel-font text-white text-lg">
            技能展示
          </a>
          <a href="/projects" class="btn-mc px-8 py-3 pixel-font text-white text-lg">
            项目作品
          </a>
          <a href="/blog" class="btn-mc px-8 py-3 pixel-font text-white text-lg">
            日记文章
          </a>
        </div>

        <!-- 社交链接 -->
        <div class="flex gap-4 justify-center mt-12 animate-fade-in delay-400">
          <a href="https://github.com" target="_blank" class="w-12 h-12 bg-[#654321] border-2 border-[#4CAF50] flex items-center justify-center hover:bg-[#4CAF50] transition-all">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="https://twitter.com" target="_blank" class="w-12 h-12 bg-[#654321] border-2 border-[#4CAF50] flex items-center justify-center hover:bg-[#4CAF50] transition-all">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
          <a href="/contact" class="w-12 h-12 bg-[#654321] border-2 border-[#4CAF50] flex items-center justify-center hover:bg-[#4CAF50] transition-all">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
