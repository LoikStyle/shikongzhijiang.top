---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    href: '/about',
    icon: '/images/textures/item/knowledge_book.png',
    label: 'MyOperatingSystem',
    title: '我的操作系统',
    desc: '思维方式 · 价值观 · 决策框架',
    blockColor: '#4CAF50',
  },
  {
    href: '/projects',
    icon: '/images/textures/item/diamond_pickaxe.png',
    label: 'Playground',
    title: '能力演示场',
    desc: '可交互的项目与能力展示',
    blockColor: '#4FC3F7',
  },
  {
    href: '/thinking',
    icon: '/images/textures/item/map.png',
    label: 'ThinkingFeed',
    title: '思考流',
    desc: '思维记录 · 知识图谱 · 洞察',
    blockColor: '#FFD54F',
  },
  {
    href: '/proof',
    icon: '/images/textures/item/nether_star.png',
    label: 'ProofOfWork',
    title: '工作证明',
    desc: '可验证的技能与经历',
    blockColor: '#9C27B0',
  },
  {
    href: '/interface',
    icon: '/images/textures/item/ender_eye.png',
    label: 'Interface',
    title: '对接协议',
    desc: '连接方式 · 合作接口',
    blockColor: '#E91E63',
  },
  {
    href: '/live',
    icon: '/images/textures/item/totem_of_undying.png',
    label: 'LiveAgent',
    title: 'AI 分身',
    desc: '在线的AI版山禾 · 随时对话',
    blockColor: '#4CAF50',
    isNew: true
  },
];
---

<Layout title="山禾 - 个人操作系统">
  <Header />

  <main class="py-12" transition:animate="fade">
    <div class="container-pixel">

      <!-- Hero：玩家卡片 + 简介 -->
      <div class="flex flex-col md:flex-row items-center gap-8 mb-14 animate-fade-in">
        <!-- 玩家头像 -->
        <div class="flex-shrink-0">
          <div class="w-28 h-28 bg-[#4CAF50] border-4 border-[#654321] relative overflow-hidden animate-float"
               style="box-shadow: 6px 6px 0 #8B4513;">
            <div class="absolute top-0 left-0 right-0 h-[30%] bg-[#66BB6A]"></div>
            <div class="absolute bottom-0 left-0 right-0 h-[70%] bg-[#8B4513]"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <img src="/images/icons/player.png" alt="山禾" class="w-20 h-20 object-contain mc-icon relative z-10" />
            </div>
          </div>
        </div>

        <!-- 文字介绍 -->
        <div>
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2 h-2 bg-[#4CAF50] rounded-full animate-pulse"></span>
            <span class="text-xs text-[#388E3C] pixel-font">在线 · 开放合作</span>
          </div>
          <h1 class="pixel-font text-4xl md:text-5xl text-[#593925] mb-2"
              style="text-shadow: 3px 3px 0 #A0522D;">山禾</h1>
          <p class="pixel-font text-lg text-[#388E3C] mb-3">
            构建 AI/Agent 时代的个人操作系统
          </p>
          <p class="text-sm text-[#6B3A2A] leading-relaxed max-w-md mb-5">
            热爱技术与创造的开发者，探索人类智慧与 AI 协作的边界。
            相信工具改变思维，思维改变世界。
          </p>
          <!-- CTA -->
          <div class="flex flex-wrap gap-3">
            <a href="/about" class="pixel-btn px-5 py-2 flex items-center gap-2 text-sm">
              <img src="/images/textures/item/knowledge_book.png" alt="" class="w-5 h-5 mc-icon" />
              探索我的OS
            </a>
            <a href="/live"
               class="flex items-center gap-2 px-5 py-2 border-4 border-[#654321] bg-white text-[#593925] pixel-font text-sm transition-all hover:bg-[#E8F5E9] hover:text-[#388E3C]"
               style="box-shadow: 3px 3px 0 #8B4513;">
              <span class="w-2 h-2 bg-[#4CAF50] rounded-full animate-pulse"></span>
              与AI分身对话
            </a>
          </div>
        </div>
      </div>

      <!-- 分割线 -->
      <div class="flex items-center gap-4 mb-10">
        <div class="flex-1 pixel-line"></div>
        <span class="pixel-font text-[#8B4513] text-sm px-2">探索地图</span>
        <div class="flex-1 pixel-line"></div>
      </div>

      <!-- 六大模块导航 -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-5 mb-8">
        {sections.map((section, index) => (
          <a
            href={section.href}
            class="pixel-card p-5 text-center card-hover group animate-fade-in relative overflow-hidden"
            style={`animation-delay: ${index * 0.07}s; background: white;`}
          >
            {section.isNew && (
              <div class="absolute top-2 right-2 px-1.5 py-0.5 bg-[#4CAF50] text-white text-[10px] pixel-font border border-[#388E3C]">
                NEW
              </div>
            )}

            <!-- MC方块图标 -->
            <div
              class="w-16 h-16 mx-auto mb-4 border-4 border-[#654321] flex items-center justify-center relative overflow-hidden transition-transform group-hover:scale-105"
              style={`background: linear-gradient(180deg, ${section.blockColor}dd 0%, ${section.blockColor}99 100%); box-shadow: inset 0 4px 0 rgba(255,255,255,0.25), inset 0 -4px 0 rgba(0,0,0,0.18), 3px 3px 0 #654321;`}
            >
              <div class="absolute top-0 left-0 right-0 h-[25%] bg-white/10"></div>
              <img src={section.icon} alt={section.title} class="w-10 h-10 object-contain mc-icon relative z-10" />
            </div>

            <!-- 英文小标签 -->
            <div class="text-[11px] text-[#7A4A2A] mb-1 pixel-font tracking-wide">{section.label}</div>

            <!-- 中文标题 -->
            <h3 class="pixel-font text-[15px] text-[#4A2C1A] mb-2 group-hover:text-[#388E3C] transition-colors leading-tight">
              {section.title}
            </h3>

            <!-- 描述 -->
            <p class="text-xs text-[#7A4A2A] leading-relaxed">{section.desc}</p>

            <!-- 进入箭头 -->
            <div class="mt-3 text-xs text-[#388E3C] opacity-0 group-hover:opacity-100 transition-opacity pixel-font">
              进入 →
            </div>
          </a>
        ))}
      </div>

    </div>
  </main>

  <Footer />
</Layout>
