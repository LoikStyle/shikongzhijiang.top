---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Particles from '../components/Particles.astro';

// 导航区块数据 - 使用MC图标
const navBlocks = [
  { href: '/about', icon: '/images/icons/player.png', iconType: 'image', title: '关于我', desc: '个人简介', color: '#8B4513' },
  { href: '/skills', icon: '/images/icons/sword.png', iconType: 'image', title: '技能展示', desc: '技术栈', color: '#4CAF50' },
  { href: '/projects', icon: '/images/icons/chest.png', iconType: 'image', title: '项目作品', desc: '项目合集', color: '#5D4037' },
  { href: '/blog', icon: '/images/icons/book.png', iconType: 'image', title: '日记文章', desc: '学习记录', color: '#1976D2' },
  { href: '/contact', icon: '/images/icons/paper.png', iconType: 'image', title: '联系我', desc: '联系方式', color: '#E91E63' },
];
---

<Layout title="山禾 - 首页">
  <Particles />
  <Header />

  <main class="py-8" transition:animate="fade">
    <div class="container-pixel">
      <!-- 欢迎横幅 -->
      <div class="pixel-card p-6 mb-8 bg-gradient-to-r from-[#FBF2DB] to-[#F5E6C8]">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <!-- 左侧：玩家信息 -->
          <div class="flex items-center gap-4">
            <div class="w-24 h-24 bg-[#4CAF50] border-4 border-[#654321] p-1">
              <div class="w-full h-full bg-[#8B4513] flex items-center justify-center">
                <img src="/images/icons/player.png" alt="玩家" class="w-20 h-20 object-contain pixel-icon" />
              </div>
            </div>
            <div>
              <h1 class="pixel-font text-3xl text-[#593925]">山禾</h1>
              <p class="text-[#8B4513] text-sm">Lv.3 初级开发者</p>
            </div>
          </div>
          <!-- 右侧：服务器状态 -->
          <div class="flex items-center gap-4 text-center">
            <div class="bg-[#593925] px-4 py-2">
              <p class="text-[#FFD700] pixel-font text-sm">在线</p>
              <p class="text-white text-xs">状态良好</p>
            </div>
          </div>
        </div>
      </div>

      <!-- 主导航区块 -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
        {navBlocks.map((block, index) => (
          <a
            href={block.href}
            class="pixel-card p-4 text-center card-hover group animate-fade-in"
            style={`animation-delay: ${index * 0.1}s`}
          >
            <!-- MC图标方块 -->
            <div
              class="w-20 h-20 mx-auto mb-3 border-4 border-[#654321] flex items-center justify-center transition-transform group-hover:scale-110 relative"
              style={`background: linear-gradient(180deg, ${block.color} 0%, ${block.color}dd 100%);`}
            >
              <img
                src={block.icon}
                alt={block.title}
                class="w-16 h-16 object-contain pixel-icon"
              />
            </div>
            <!-- 标题 -->
            <h3 class="pixel-font text-lg text-[#593925] mb-1">{block.title}</h3>
            <!-- 描述 -->
            <p class="text-xs text-[#8B4513]">{block.desc}</p>
          </a>
        ))}
      </div>

      <!-- 下方两个区块 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- 公告牌 -->
        <div class="pixel-card p-6 bg-[#A1887F]">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-2xl">📜</span>
            <h2 class="pixel-font text-xl text-[#593925]">公告牌</h2>
          </div>
          <div class="bg-[#8D6E63] border-4 border-[#5D4037] p-4">
            <p class="text-[#FFF3E0] pixel-font text-center text-lg">
              "欢迎来到山禾的世界！<br/>这里记录了我的学习与成长历程"
            </p>
          </div>
          <div class="flex justify-center mt-4">
            <div class="flex gap-1">
              <div class="w-3 h-4 bg-[#593925]"></div>
              <div class="w-3 h-4 bg-[#593925]"></div>
            </div>
          </div>
        </div>

        <!-- 快速链接 -->
        <div class="pixel-card p-6 bg-[#BCAAA4]">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-2xl">🔗</span>
            <h2 class="pixel-font text-xl text-[#593925]">快速链接</h2>
          </div>
          <div class="space-y-3">
            <a href="https://github.com" target="_blank" class="flex items-center gap-3 p-3 bg-[#593925]/10 hover:bg-[#593925]/20 rounded transition-colors">
              <img src="/images/icons/diamond.png" alt="GitHub" class="w-8 h-8 object-contain pixel-icon" />
              <span class="pixel-font text-[#593925]">GitHub</span>
              <span class="ml-auto text-[#593925]">→</span>
            </a>
            <a href="https://juejin.cn" target="_blank" class="flex items-center gap-3 p-3 bg-[#593925]/10 hover:bg-[#593925]/20 rounded transition-colors">
              <img src="/images/icons/book.png" alt="掘金" class="w-8 h-8 object-contain pixel-icon" />
              <span class="pixel-font text-[#593925]">掘金</span>
              <span class="ml-auto text-[#593925]">→</span>
            </a>
            <a href="/contact" class="flex items-center gap-3 p-3 bg-[#593925]/10 hover:bg-[#593925]/20 rounded transition-colors">
              <img src="/images/icons/paper.png" alt="留言板" class="w-8 h-8 object-contain pixel-icon" />
              <span class="pixel-font text-[#593925]">留言板</span>
              <span class="ml-auto text-[#593925]">→</span>
            </a>
          </div>
        </div>
      </div>

      <!-- 底部统计 -->
      <div class="mt-8 flex flex-wrap justify-center gap-6">
        <div class="flex items-center gap-2 bg-[#593925] px-4 py-2">
          <span class="text-[#FFD700]">📅</span>
          <span class="text-white pixel-font text-sm">2024年入驻</span>
        </div>
        <div class="flex items-center gap-2 bg-[#4CAF50] px-4 py-2">
          <span class="text-white">⚡</span>
          <span class="text-white pixel-font text-sm">持续学习中</span>
        </div>
        <div class="flex items-center gap-2 bg-[#E91E63] px-4 py-2">
          <span class="text-white">❤️</span>
          <span class="text-white pixel-font text-sm">感谢访问</span>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
