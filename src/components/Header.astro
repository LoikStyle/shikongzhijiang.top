---
// Header.astro - 顶部导航组件
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#f5f5f5]/95 backdrop-blur-sm border-b-4 border-[#654321]">
  <nav class="container-pixel py-3 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 pixel-font text-xl text-[#388E3C] hover:text-[#4CAF50] transition-colors">
      <span class="w-8 h-8 bg-[#4CAF50] border-2 border-[#654321] inline-block" style="box-shadow: inset 2px 2px 0 rgba(255,255,255,0.3), inset -2px -2px 0 rgba(0,0,0,0.2);"></span>
      山禾
    </a>

    <!-- 导航链接 -->
    <ul class="flex items-center gap-6">
      <li>
        <a href="#hero" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-colors">
          首页
        </a>
      </li>
      <li>
        <a href="#skills" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-colors">
          技能
        </a>
      </li>
      <li>
        <a href="#blog" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-colors">
          文章
        </a>
      </li>
      <li>
        <a href="#social" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-colors">
          联系
        </a>
      </li>
    </ul>
  </nav>

  <!-- 草方块装饰 -->
  <div class="absolute -bottom-3 left-0 right-0 h-3 bg-[#4CAF50] opacity-20 pointer-events-none"></div>
</header>

<!-- 占位元素，防止固定头部遮挡内容 -->
<div class="h-20"></div>
