---
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#faf8f5]/95 backdrop-blur-sm border-b-4 border-[#654321]" transition:persist>
  <nav class="container-pixel py-3 flex items-center justify-between">
    <!-- Logo - 草方块 -->
    <a href="/" class="flex items-center gap-2 pixel-font text-xl text-[#388E3C] hover:text-[#4CAF50] transition-all group">
      <span class="w-8 h-8 inline-block relative border-2 border-[#654321] overflow-hidden flex-shrink-0" style="image-rendering: pixelated;">
        <img src="/images/textures/block/grass_block_side.png" alt="" class="w-full h-full object-cover mc-icon" />
      </span>
      <span class="group-hover:animate-pulse">山禾</span>
    </a>

    <!-- 桌面导航 -->
    <ul class="hidden md:flex items-center gap-1">
      <li>
        <a href="/" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 block text-sm">首页</a>
      </li>
      <li>
        <a href="/about" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 block text-sm">我的OS</a>
      </li>
      <li>
        <a href="/projects" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 block text-sm">能力演示</a>
      </li>
      <li>
        <a href="/thinking" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 block text-sm">思考流</a>
      </li>
      <li>
        <a href="/proof" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 block text-sm">工作证明</a>
      </li>
      <li>
        <a href="/interface" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 block text-sm">对接协议</a>
      </li>
      <li>
        <a href="/live" class="flex items-center gap-1.5 pixel-font text-sm px-3 py-1.5 bg-[#4CAF50] border-2 border-[#654321] text-white hover:bg-[#388E3C] transition-all" style="box-shadow: 2px 2px 0 #654321;">
          <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span>
          AI分身
        </a>
      </li>
    </ul>

    <!-- 移动端菜单按钮 -->
    <button class="md:hidden text-[#654321] hover:text-[#4CAF50] p-2 pixel-font" id="mobile-menu-btn">☰</button>
  </nav>

  <!-- 移动端菜单 -->
  <div class="hidden md:hidden bg-[#faf8f5] border-t-2 border-[#654321]" id="mobile-menu">
    <div class="container-pixel py-2 space-y-1">
      <a href="/" class="block px-3 py-2 pixel-font text-[#654321] hover:text-[#4CAF50] hover:bg-[#4CAF50]/10">首页</a>
      <a href="/about" class="block px-3 py-2 pixel-font text-[#654321] hover:text-[#4CAF50] hover:bg-[#4CAF50]/10">我的OS</a>
      <a href="/projects" class="block px-3 py-2 pixel-font text-[#654321] hover:text-[#4CAF50] hover:bg-[#4CAF50]/10">能力演示</a>
      <a href="/thinking" class="block px-3 py-2 pixel-font text-[#654321] hover:text-[#4CAF50] hover:bg-[#4CAF50]/10">思考流</a>
      <a href="/proof" class="block px-3 py-2 pixel-font text-[#654321] hover:text-[#4CAF50] hover:bg-[#4CAF50]/10">工作证明</a>
      <a href="/interface" class="block px-3 py-2 pixel-font text-[#654321] hover:text-[#4CAF50] hover:bg-[#4CAF50]/10">对接协议</a>
      <a href="/live" class="block px-3 py-2 pixel-font text-[#4CAF50]">⚡ AI分身</a>
    </div>
  </div>

  <!-- 草方块装饰条 -->
  <div class="absolute -bottom-3 left-0 right-0 h-3 pointer-events-none overflow-hidden">
    <div class="flex">
      {Array(100).fill(0).map(() => (
        <div class="w-3 h-3 bg-[#4CAF50] border-t border-[#66BB6A] flex-shrink-0" style="opacity: 0.4;"></div>
      ))}
    </div>
  </div>
</header>

<div class="h-20"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
