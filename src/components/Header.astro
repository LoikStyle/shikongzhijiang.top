---
// Header.astro - 顶部导航组件
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#faf8f5]/95 backdrop-blur-sm border-b-4 border-[#654321]">
  <nav class="container-pixel py-3 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 pixel-font text-xl text-[#388E3C] hover:text-[#4CAF50] transition-all group">
      <span class="w-8 h-8 bg-[#4CAF50] border-2 border-[#654321] inline-block relative" style="box-shadow: inset 2px 2px 0 rgba(255,255,255,0.3), inset -2px -2px 0 rgba(0,0,0,0.2);">
        <span class="absolute top-0 left-0 w-full h-[30%] bg-[#66BB6A]"></span>
        <span class="absolute bottom-0 left-0 w-full h-[70%] bg-[#8B4513]"></span>
      </span>
      <span class="group-hover:animate-pulse">山禾</span>
    </a>

    <!-- 导航链接 -->
    <ul class="flex items-center gap-1 md:gap-2">
      <li>
        <a href="/" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 rounded block">
          首页
        </a>
      </li>
      <li>
        <a href="/about" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 rounded block">
          关于
        </a>
      </li>
      <li>
        <a href="/skills" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 rounded block">
          技能
        </a>
      </li>
      <li>
        <a href="/projects" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 rounded block">
          项目
        </a>
      </li>
      <li>
        <a href="/blog" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 rounded block">
          日记
        </a>
      </li>
      <li>
        <a href="/contact" class="pixel-font text-[#654321] hover:text-[#4CAF50] transition-all px-3 py-2 hover:bg-[#4CAF50]/10 rounded block">
          联系
        </a>
      </li>
    </ul>
  </nav>

  <!-- 草方块装饰 -->
  <div class="absolute -bottom-3 left-0 right-0 h-3 pointer-events-none">
    <div class="flex">
      {Array(50).fill(0).map(() => (
        <div class="w-3 h-3 bg-[#4CAF50] border-t border-[#66BB6A]" style="opacity: 0.3;"></div>
      ))}
    </div>
  </div>
</header>

<!-- 占位元素 -->
<div class="h-20"></div>
