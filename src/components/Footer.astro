---
// Footer.astro - 页脚组件
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#654321] text-white py-8 relative overflow-hidden" transition:persist>
  <!-- 背景装饰 -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-0 w-full h-2 bg-[#4CAF50] opacity-30"></div>
    <div class="absolute bottom-0 left-0 w-20 h-20 bg-[#4CAF50]/10 transform -translate-x-1/2 translate-y-1/2"></div>
    <div class="absolute top-0 right-0 w-16 h-16 bg-[#8B4513]/20 transform translate-x-1/2 -translate-y-1/2"></div>
  </div>

  <div class="container-pixel relative z-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- 版权信息 -->
      <div class="text-center md:text-left">
        <p class="pixel-font text-lg flex items-center gap-2">
          <span class="w-4 h-4 bg-[#4CAF50] inline-block" style="box-shadow: inset 1px 1px 0 rgba(255,255,255,0.3);"></span>
          © {currentYear} 山禾
        </p>
        <p class="text-sm opacity-75 flex items-center gap-2">
          <span class="w-2 h-2 bg-[#4CAF50] rounded-full animate-pulse"></span>
          保留所有权利
        </p>
      </div>

      <!-- 装饰性像素方块 -->
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 bg-[#4CAF50] border-2 border-[#3E2723] relative animate-bounce" style="animation-delay: 0s;">
          <div class="absolute top-0 left-0 right-0 h-[30%] bg-[#66BB6A]"></div>
        </div>
        <div class="w-6 h-6 bg-[#8B4513] border-2 border-[#3E2723] animate-bounce" style="animation-delay: 0.2s;"></div>
        <div class="w-6 h-6 bg-[#757575] border-2 border-[#3E2723] animate-bounce" style="animation-delay: 0.4s;"></div>
        <div class="w-6 h-6 bg-[#4CAF50]/50 border-2 border-[#3E2723] animate-bounce" style="animation-delay: 0.6s;"></div>
      </div>

      <!-- 备案信息 -->
      <div class="text-center md:text-right">
        <p class="text-sm opacity-75 hover:opacity-100 transition-opacity">
          <a href="https://beian.miit.gov.cn" target="_blank" rel="noopener noreferrer" class="hover:text-[#4CAF50] transition-colors inline-flex items-center gap-1">
            <span class="w-3 h-3 border border-current flex items-center justify-center text-[10px]">ICP</span>
            粤ICP备xxxxxxxx号
          </a>
        </p>
        <p class="text-xs opacity-50 mt-1">
          Powered by Astro
        </p>
      </div>
    </div>

    <!-- 底部装饰 -->
    <div class="mt-6 pt-4 border-t border-[#3E2723]/50">
      <div class="flex justify-center gap-1">
        {Array(20).fill(0).map((_, i) => (
          <div class={`w-2 h-2 ${i % 3 === 0 ? 'bg-[#4CAF50]' : i % 3 === 1 ? 'bg-[#8B4513]' : 'bg-[#757575]'} opacity-50`}></div>
        ))}
      </div>
    </div>
  </div>
</footer>
