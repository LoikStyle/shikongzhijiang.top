---
// Hero.astro - 个人简介区域
---

<section id="hero" class="py-16 md:py-24">
  <div class="container-pixel">
    <div class="flex flex-col md:flex-row items-center gap-8">
      <!-- 像素风格头像 -->
      <div class="relative animate-float">
        <div class="w-40 h-40 md:w-48 md:h-48 bg-[#4CAF50] border-4 border-[#654321] p-2">
          <div class="w-full h-full bg-[#8B4513] border-2 border-[#654321] flex items-center justify-center">
            <!-- 简单的像素人物图标 -->
            <svg viewBox="0 0 64 64" class="w-24 h-24 md:w-32 md:h-32" xmlns="http://www.w3.org/2000/svg">
              <!-- 头发 -->
              <rect x="16" y="8" width="32" height="16" fill="#654321" />
              <!-- 脸部 -->
              <rect x="20" y="20" width="24" height="20" fill="#FFDAB9" />
              <!-- 眼睛 -->
              <rect x="26" y="28" width="4" height="4" fill="#333" />
              <rect x="34" y="28" width="4" height="4" fill="#333" />
              <!-- 嘴巴 -->
              <rect x="28" y="36" width="8" height="2" fill="#8B4513" />
              <!-- 身体 -->
              <rect x="20" y="42" width="24" height="16" fill="#4CAF50" />
            </svg>
          </div>
        </div>
        <!-- 装饰性草方块 -->
        <div class="absolute -top-2 -right-2 w-6 h-6 bg-[#4CAF50] border-2 border-[#654321]"></div>
      </div>

      <!-- 文字介绍 -->
      <div class="text-center md:text-left">
        <h1 class="pixel-font text-4xl md:text-5xl text-[#388E3C] mb-4">
          你好，我是山禾
        </h1>
        <p class="text-lg text-[#666666] mb-6 max-w-lg">
          一名热爱技术的开发者，专注于前端开发与用户体验设计。喜欢探索新技术，喜欢创造有趣的东西。
        </p>
        <!-- 社交图标 -->
        <div class="flex gap-4 justify-center md:justify-start">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 bg-[#654321] border-2 border-[#4CAF50] flex items-center justify-center hover:bg-[#4CAF50] transition-colors">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 bg-[#654321] border-2 border-[#4CAF50] flex items-center justify-center hover:bg-[#4CAF50] transition-colors">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
          <a href="mailto:example@email.com"
             class="w-10 h-10 bg-[#654321] border-2 border-[#4CAF50] flex items-center justify-center hover:bg-[#4CAF50] transition-colors">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
