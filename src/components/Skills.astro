---
// Skills.astro - 技能展示组件

interface Skill {
  name: string;
  description: string;
  icon: string;
}

const skills: Skill[] = [
  {
    name: 'HTML/CSS',
    description: '熟练掌握 HTML5、CSS3，能够实现响应式布局和动画效果',
    icon: 'html'
  },
  {
    name: 'JavaScript',
    description: '熟悉 ES6+ 语法，了解 TypeScript，能够开发交互式网页',
    icon: 'js'
  },
  {
    name: 'React',
    description: '能够使用 React 构建单页应用，熟悉 Hooks 和状态管理',
    icon: 'react'
  },
  {
    name: 'Vue',
    description: '掌握 Vue3 组合式 API，有实际项目开发经验',
    icon: 'vue'
  },
  {
    name: 'Node.js',
    description: '能够使用 Express/Koa 搭建后端服务，了解 RESTful API 设计',
    icon: 'node'
  },
  {
    name: 'Git',
    description: '熟练使用 Git 进行版本控制，了解团队协作流程',
    icon: 'git'
  }
];
---

<section id="skills" class="py-16 bg-white">
  <div class="container-pixel">
    <h2 class="section-title text-center mb-12">我的技能</h2>

    <!-- 像素装饰线 -->
    <div class="pixel-line mb-12"></div>

    <!-- 技能网格 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {skills.map((skill) => (
        <div class="pixel-card p-6 hover:translate-y-[-4px] transition-transform">
          <!-- 技能图标 -->
          <div class="w-16 h-16 bg-[#4CAF50] border-4 border-[#654321] mb-4 flex items-center justify-center">
            {skill.icon === 'html' && (
              <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M1.5 0h21l-1.91 21.563L11.977 24l-8.564-2.438L1.5 0zm7.031 9.75l-.232-2.718 10.059.003.23-2.622L5.412 4.41l.698 8.01h9.126l-.326 3.426-2.91.804-2.955-.81-.188-2.11H6.248l.33 4.171L12 19.351l5.379-1.443.744-8.157H8.531z"/>
              </svg>
            )}
            {skill.icon === 'js' && (
              <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M0 0h24v24H0V0zm22.034 18.276c-.175-1.095-.888-2.015-3.003-2.873-.736-.345-1.554-.585-1.797-1.14-.091-.33-.105-.51-.046-.705.15-.646.915-.84 1.515-.66.39.12.75.42.976.9 1.034-.676 1.034-.676 1.755-1.125-.27-.42-.404-.601-.586-.78-.63-.705-1.469-1.065-2.834-1.034l-.705.089c-.676.165-1.32.525-1.71 1.005-1.14 1.291-.811 3.541.569 4.471 1.365 1.02 3.361 1.244 3.616 2.205.24 1.17-.87 1.545-1.966 1.41-.811-.18-1.26-.586-1.755-1.336l-1.83 1.051c.21.48.45.689.81 1.109 1.74 1.756 6.09 1.666 6.871-1.004.029-.09.24-.705.074-1.65l.046.067zm-8.983-7.245h-2.248c0 1.938-.009 3.864-.009 5.805 0 1.232.063 2.363-.138 2.711-.33.689-1.18.601-1.566.48-.396-.196-.597-.466-.83-.855-.063-.105-.11-.196-.127-.196l-1.825 1.125c.305.63.75 1.172 1.324 1.517.855.51 2.004.675 3.207.405.783-.226 1.458-.691 1.811-1.411.51-.93.402-2.07.397-3.346.012-2.054 0-4.109 0-6.179l.004-.056z"/>
              </svg>
            )}
            {skill.icon === 'react' && (
              <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.999 0c-2.094 0-3.794 1.7-3.794 3.794 0 2.094 1.7 3.794 3.794 3.794 2.094 0 3.794-1.7 3.794-3.794 0-2.094-1.7-3.794-3.794-3.794zM16.408 8.761c-.502-.252-1.123-.252-1.656-.036-1.335.541-2.066 1.97-1.893 3.465.087.756.381 1.45.793 2 .755 1.012 1.826 1.683 3.027 1.868.726.112 1.456-.048 2.114-.417.636-.356 1.095-.858 1.282-1.467.187-.609.154-1.252-.048-1.852-.198-.588-.55-1.099-1.001-1.517-.468-.433-.992-.767-1.563-.998-.552-.224-1.13-.356-1.731-.356-.602 0-1.18.132-1.731.356-.571.231-1.095.565-1.563.998-.451.418-.803.929-1.001 1.517-.202.6-.235 1.243-.048 1.852.187.609.646 1.111 1.282 1.467.658.369 1.388.529 2.114.417 1.201-.185 2.272-.856 3.027-1.868.412-.55.706-1.244.793-2 .173-1.495-.558-2.924-1.893-3.465-.533-.216-1.154-.216-1.656.036-.527.265-.906.726-1.096 1.257-.19.531-.213 1.102-.036 1.629.177.527.543.983 1.036 1.286.465.285.986.439 1.525.439.54 0 1.06-.154 1.525-.44.493-.302.86-.758 1.036-1.286.177-.527.154-1.098-.036-1.629-.19-.531-.569-.992-1.096-1.257z"/>
              </svg>
            )}
            {skill.icon === 'vue' && (
              <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 1.61h-9.94L12 5.16 9.94 1.61H0l12 20.78L24 1.61zM12 14.08 5.16 2.23h4.43L12 6.41l2.41-4.18h4.43L12 14.08z"/>
              </svg>
            )}
            {skill.icon === 'node' && (
              <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.998 0C5.366 0 0 5.367 0 12a11.992 11.992 0 001.314 6.124c.16.005.313.011.46.011.274 0 .543-.027.811-.047a11.994 11.994 0 009.429-4.525c.232-.417.428-.851.59-1.3.02-.053.046-.102.06-.156a11.992 11.992 0 001.314-6.107C23.995 5.366 18.628 0 11.998 0zM12.002 1.675c3.944 0 7.152 3.188 7.152 7.152 0 2.723-1.523 5.098-3.749 6.347a10.87 10.87 0 01-2.785-4.86c.11-.005.22-.01.322-.016-.236-.596-.44-1.222-.598-1.86-.485 0-.95.06-1.4.172a8.176 8.176 0 00-4.713 1.285 8.197 8.197 0 00-3.066-1.285c-.45-.112-.915-.172-1.4-.172a8.187 8.187 0 00-5.19 1.883 8.196 8.196 0 00-3.066 4.856 10.87 10.87 0 01-2.784 4.86c-2.226-1.25-3.749-3.624-3.749-6.347 0-3.964 3.208-7.152 7.152-7.152 1.192 0 2.34.3 3.382.843a8.17 8.17 0 012.457 2.033 8.177 8.177 0 01-2.457 2.033c-1.042.543-2.19.843-3.382.843zm-1.275 1.639c-2.52 0-4.568 2.04-4.568 4.557 0 1.12.406 2.147 1.09 2.955a3.86 3.86 0 00.858 2.143 8.18 8.18 0 01-1.467-3.567c0-.447.037-.89.108-1.322a8.17 8.17 0 01.78-2.835 8.15 8.15 0 012.8-2.066c.94-.412 1.98-.608 3.063-.478a8.148 8.148 0 012.456 1.132 8.155 8.155 0 01-1.066 3.597 8.14 8.14 0 01.866 2.953 8.163 8.163 0 01-1.132 3.396 8.166 8.166 0 01-3.01 1.833c-1.34.412-2.773.412-4.113 0-1.073-.329-2.013-.9-2.73-1.64a4.594 4.594 0 01-.858-1.063 4.672 4.672 0 01-.543-1.196 4.562 4.562 0 01-.202-1.262c2.52 0 4.568-2.04 4.568-4.557 0-1.12-.406-2.147-1.09-2.955a3.851 3.851 0 00-.858-2.143 8.168 8.168 0 011.467 3.567c0 .447-.037.89-.108 1.322a8.172 8.172 0 01-.78 2.835 8.15 8.15 0 01-2.8 2.066c-.94.412-1.98.608-3.063.478a8.148 8.148 0 01-2.456-1.132 8.155 8.155 0 011.066-3.597 8.142 8.142 0 01-.866-2.953 8.164 8.164 0 011.132-3.396c.84-.616 1.867-.993 2.965-1.093z"/>
              </svg>
            )}
            {skill.icon === 'git' && (
              <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.546 10.93L13.067.452c-.6-.6-1.48-.6-2.133 0L8.708 2.627l2.76 2.73c.645-.215 1.379-.07 1.889.441.516.515.658 1.258.438 1.9l2.658 2.66c.645-.223 1.387-.078 1.9.435.721.72.721 1.884 0 2.6-.719.719-1.881.719-2.6 0-.539-.541-.674-1.337-.404-1.996L12.86 8.955v6.525c.176.086.342.203.488.348.713.721.713 1.883 0 2.6-.716.716-1.881.716-2.6 0-.716-.719-.716-1.884 0-2.603.256-.253.563-.448.885-.577v-6.504c-.322-.129-.629-.324-.885-.577-.503-.5-.606-1.233-.303-1.829L12.002.98l-4.199 4.192c.304.596.199 1.33-.303 1.829-.503.5-1.233.603-1.829.303L.452 10.93c-.596-.304-1.33-.199-1.829.303-.5.503-.603 1.233-.303 1.829l9.227 9.21c.5.503 1.233.606 1.829.303l5.25-5.242c.5-.503.606-1.233.303-1.829l-2.28-2.28c.304-.596.199-1.33-.303-1.829z"/>
              </svg>
            )}
          </div>

          <!-- 技能名称 -->
          <h3 class="pixel-font text-xl text-[#388E3C] mb-2">{skill.name}</h3>

          <!-- 技能描述 -->
          <p class="text-[#666666] text-sm">{skill.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
