---
// SocialLinks.astro - 社交媒体链接组件

interface SocialLink {
  name: string;
  url: string;
  icon: string;
}

const socialLinks: SocialLink[] = [
  {
    name: 'GitHub',
    url: 'https://github.com',
    icon: 'github'
  },
  {
    name: 'Twitter',
    url: 'https://twitter.com',
    icon: 'twitter'
  },
  {
    name: '掘金',
    url: 'https://juejin.cn',
    icon: 'juejin'
  },
  {
    name: 'CSDN',
    url: 'https://blog.csdn.net',
    icon: 'csdn'
  },
  {
    name: '邮箱',
    url: 'mailto:example@email.com',
    icon: 'email'
  }
];
---

<section id="social" class="py-16 bg-white">
  <div class="container-pixel">
    <h2 class="section-title text-center mb-12">联系我</h2>

    <!-- 像素装饰线 -->
    <div class="pixel-line mb-12"></div>

    <!-- 社交链接网格 -->
    <div class="flex flex-wrap justify-center gap-6">
      {socialLinks.map((link) => (
        <a href={link.url}
           target="_blank"
           rel="noopener noreferrer"
           class="pixel-btn px-6 py-3 flex items-center gap-3 text-white pixel-font text-sm">
          {link.icon === 'github' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          )}
          {link.icon === 'twitter' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          )}
          {link.icon === 'juejin' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          )}
          {link.icon === 'csdn' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M21.5 3h-19C1.67 3 1 3.67 1 4.5v15c0 .83.67 1.5 1.5 1.5h19c.83 0 1.5-.67 1.5-1.5v-15c0-.83-.67-1.5-1.5-1.5zM12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6 6 2.69 6 6-2.69 6-6 6z"/>
            </svg>
          )}
          {link.icon === 'email' && (
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          )}
          {link.name}
        </a>
      ))}
    </div>

    <!-- 额外联系方式 -->
    <div class="mt-12 text-center">
      <p class="text-[#666666] mb-4">其他方式</p>
      <p class="pixel-font text-[#388E3C]">微信号：shikongzhijiang</p>
    </div>
  </div>
</section>
